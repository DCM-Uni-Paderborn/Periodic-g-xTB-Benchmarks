      SYMMETRY T
      FULL_GRID F
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
    &END KPOINTS
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
