# DMC13_GXTB_PROTOCOL dmc13-gxtb-spglib-reduced-v1
&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ice_VI_GXTB_k333
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.1
        &END TBLITE
        SCC_MIXER TBLITE
        &TBLITE_MIXER
          ITERATIONS 300
        &END TBLITE_MIXER
      &END XTB
    &END QS
    &KPOINTS
