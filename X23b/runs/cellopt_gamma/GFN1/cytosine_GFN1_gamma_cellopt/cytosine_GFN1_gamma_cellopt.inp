&GLOBAL
  PRINT_LEVEL LOW
  PROJECT cytosine_GFN1_gamma_cell_opt
  RUN_TYPE CELL_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
