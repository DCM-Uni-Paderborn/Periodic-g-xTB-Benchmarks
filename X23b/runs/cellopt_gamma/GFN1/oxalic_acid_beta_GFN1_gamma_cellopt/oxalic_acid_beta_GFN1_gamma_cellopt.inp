      O   0.668900000000  0.394700000000  0.298300000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &CELL_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
    EXTERNAL_PRESSURE 0.0
  &END CELL_OPT
&END MOTION
