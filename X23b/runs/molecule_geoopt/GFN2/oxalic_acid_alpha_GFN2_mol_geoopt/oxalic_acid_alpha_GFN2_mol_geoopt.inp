&GLOBAL
  PRINT_LEVEL LOW
  PROJECT oxalic_acid_alpha_GFN2_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C   0.753350000000 -0.169540000000  0.000010000000
      C  -0.753350000000  0.169540000000  0.000030000000
      O   1.138270000000 -1.307690000000 -0.000080000000
      O   1.532270000000  0.903170000000  0.000070000000
      O  -1.138270000000  1.307690000000 -0.000080000000
      O  -1.532270000000 -0.903170000000  0.000060000000
      H   0.951480000000  1.684880000000  0.000030000000
      H  -0.951470000000 -1.684880000000  0.000070000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
