&GLOBAL
  PRINT_LEVEL LOW
  PROJECT acetic_acid_GFN2_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -1.547420000000  0.047190000000 -0.000010000000
      H  -1.900880000000  1.077610000000 -0.000030000000
      H  -1.924870000000 -0.479530000000 -0.881830000000
      H  -1.924890000000 -0.479520000000  0.881800000000
      C  -0.041890000000  0.031780000000 -0.000020000000
      O   0.682520000000  1.004270000000 -0.000170000000
      O   0.448240000000 -1.236410000000  0.000210000000
      H   1.418120000000 -1.166870000000  0.000200000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
