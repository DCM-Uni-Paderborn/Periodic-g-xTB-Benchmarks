&GLOBAL
  PRINT_LEVEL LOW
  PROJECT triazine_GFN2_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -2.078110000000 -1.915380000000 -0.000000000000
      N  -0.740560000000 -1.901920000000 -0.000000000000
      C  -0.202770000000 -0.677410000000 -0.000010000000
      C  -2.212530000000  0.327700000000 -0.000020000000
      N  -2.869680000000 -0.837120000000 -0.000000000000
      H   0.882830000000 -0.611690000000 -0.000020000000
      H  -2.564570000000 -2.888080000000 -0.000010000000
      H  -2.811160000000  1.235710000000 -0.000010000000
      N  -0.882840000000  0.474630000000 -0.000000000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
