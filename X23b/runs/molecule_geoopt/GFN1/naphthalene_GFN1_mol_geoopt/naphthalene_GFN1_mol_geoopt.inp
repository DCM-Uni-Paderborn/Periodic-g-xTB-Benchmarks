      C  -5.098130000000  0.612630000000  0.000690000000
      C  -5.774390000000 -0.588360000000  0.000610000000
      H  -0.981330000000 -1.490090000000 -0.000160000000
      H  -5.600920000000 -2.752850000000  0.000260000000
      H  -3.128670000000 -2.747470000000 -0.000060000000
      C  -1.529180000000 -0.551110000000  0.000060000000
      C  -2.947870000000  1.871740000000  0.000600000000
      H  -5.645990000000  1.551610000000  0.000910000000
      H  -6.860470000000 -0.601780000000  0.000750000000
      C  -1.569570000000  1.873780000000  0.000420000000
      C  -0.852930000000  0.649890000000  0.000150000000
      H  -3.498660000000  2.808990000000  0.000810000000
      H  -1.026380000000  2.814360000000  0.000500000000
      H   0.233150000000  0.663310000000  0.000010000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
