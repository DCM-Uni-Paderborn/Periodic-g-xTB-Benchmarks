&GLOBAL
  PRINT_LEVEL LOW
  PROJECT imidazole_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -0.046750000000 -2.028570000000  0.000060000000
      C   1.659690000000 -0.729290000000 -0.000030000000
      C   0.563300000000  0.099920000000 -0.000110000000
      N  -0.527520000000 -0.747250000000 -0.000100000000
      H  -1.498120000000 -0.471960000000 -0.000220000000
      H  -0.696590000000 -2.892430000000  0.000130000000
      H   2.703720000000 -0.450580000000 -0.000010000000
      H   0.460630000000  1.174070000000 -0.000170000000
      N   1.269520000000 -2.051840000000  0.000020000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
