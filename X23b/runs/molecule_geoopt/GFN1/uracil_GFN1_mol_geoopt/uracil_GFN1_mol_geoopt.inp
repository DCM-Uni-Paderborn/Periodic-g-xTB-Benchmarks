&GLOBAL
  PRINT_LEVEL LOW
  PROJECT uracil_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -3.205460000000 -1.403290000000  0.000010000000
      N  -1.831540000000 -1.236950000000 -0.000000000000
      C  -1.103760000000 -0.027050000000 -0.000010000000
      C  -1.946410000000  1.164600000000 -0.000000000000
      C  -3.292030000000  1.035920000000  0.000010000000
      N  -3.903540000000 -0.197500000000  0.000020000000
      H  -1.463600000000  2.131830000000 -0.000010000000
      H  -3.963270000000  1.887530000000  0.000020000000
      O   0.118790000000 -0.044580000000 -0.000030000000
      O  -3.764670000000 -2.487800000000  0.000010000000
      H  -1.285540000000 -2.091520000000 -0.000010000000
      H  -4.910150000000 -0.285410000000  0.000020000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
