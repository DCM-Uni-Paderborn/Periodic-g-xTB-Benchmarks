&GLOBAL
  PRINT_LEVEL LOW
  PROJECT urea_GXTB_k222_energy
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &KPOINTS
      SCHEME MACDONALD 2 2 2 0.25 0.25 0.25
      EPS_SYMMETRY 1.0E-8
      SYMMETRY T
      FULL_GRID F
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
    &END KPOINTS
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      CANONICALIZE TRUE
      PERIODIC XYZ
      A 5.565000000000 0.000000000000 0.000000000000
      B 0.000000000000 5.565000000000 0.000000000000
      C 0.000000000000 0.000000000000 4.684000000000
    &END CELL
    &COORD
      SCALED
      C   1.000000000000  0.500000000000  0.326000000000
      C   0.500000000000  0.000000000000  0.674000000000
      O   1.000000000000  0.500000000000  0.595300000000
      O   0.500000000000  0.000000000000  0.404700000000
      N   0.145900000000  0.645900000000  0.176600000000
      N   0.645900000000  0.854100000000  0.823400000000
      N   0.354100000000  0.145900000000  0.823400000000
      N   0.854100000000  0.354100000000  0.176600000000
      H   0.257500000000  0.757500000000  0.282700000000
      H   0.757500000000  0.742500000000  0.717300000000
      H   0.242500000000  0.257500000000  0.717300000000
      H   0.742500000000  0.242500000000  0.282700000000
      H   0.144100000000  0.644100000000  0.962000000000
      H   0.644100000000  0.855900000000  0.038000000000
      H   0.355900000000  0.144100000000  0.038000000000
      H   0.855900000000  0.355900000000  0.962000000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
