&GLOBAL
  PRINT_LEVEL LOW
  PROJECT pyrazine_GXTB_k222_energy
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &KPOINTS
      SCHEME MACDONALD 2 2 2 0.25 0.25 0.25
      EPS_SYMMETRY 1.0E-8
      SYMMETRY T
      FULL_GRID F
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
    &END KPOINTS
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
