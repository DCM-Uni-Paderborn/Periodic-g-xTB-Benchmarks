&GLOBAL
  PRINT_LEVEL LOW
  PROJECT oxalic_acid_alpha_GXTB_gamma_energy
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
