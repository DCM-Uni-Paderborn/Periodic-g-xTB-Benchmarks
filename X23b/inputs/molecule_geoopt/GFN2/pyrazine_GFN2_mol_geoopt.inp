&GLOBAL
  PRINT_LEVEL LOW
  PROJECT pyrazine_GFN2_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C   0.392500000000 -0.541320000000 -0.000000000000
      C   1.790670000000 -0.541310000000  0.000010000000
      N   2.500280000000  0.593810000000 -0.000010000000
      C   1.790650000000  1.728900000000 -0.000050000000
      C   0.392470000000  1.728890000000 -0.000060000000
      N  -0.317140000000  0.593780000000 -0.000040000000
      H  -0.165830000000 -1.474460000000  0.000030000000
      H   2.349010000000 -1.474440000000  0.000050000000
      H   2.348960000000  2.662050000000 -0.000080000000
      H  -0.165860000000  2.662020000000 -0.000110000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
