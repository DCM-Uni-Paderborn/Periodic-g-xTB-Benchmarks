&GLOBAL
  PRINT_LEVEL LOW
  PROJECT benzene_GFN2_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C   0.004350000000 -0.190830000000  0.000070000000
      C   1.402840000000 -0.190810000000  0.000590000000
      C   2.102100000000  1.020020000000 -0.000100000000
      C   1.402900000000  2.231160000000 -0.001030000000
      C   0.004610000000  2.231140000000 -0.001420000000
      C  -0.694760000000  1.020140000000 -0.000990000000
      H  -0.538630000000 -1.131560000000  0.000440000000
      H   1.945760000000 -1.131600000000  0.001370000000
      H   3.188290000000  1.020050000000  0.000170000000
      H   1.946110000000  3.171750000000 -0.001450000000
      H  -0.538520000000  3.171800000000 -0.002250000000
      H  -1.780940000000  1.020380000000 -0.001330000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
