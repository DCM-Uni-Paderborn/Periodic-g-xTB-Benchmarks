&GLOBAL
  PRINT_LEVEL LOW
  PROJECT cytosine_GXTB_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -0.596030000000 -0.115030000000  0.137360000000
      C   1.431320000000  1.228780000000 -0.153530000000
      C  -0.660630000000  2.258200000000 -0.008350000000
      C  -1.363480000000  1.008420000000  0.143540000000
      H  -1.006250000000 -1.113810000000  0.243410000000
      H   1.342530000000 -0.834680000000 -0.012940000000
      H  -2.438240000000  0.958540000000  0.262100000000
      N   0.749100000000 -0.015750000000 -0.004400000000
      N   0.649500000000  2.355160000000 -0.149550000000
      O   2.648930000000  1.209130000000 -0.276110000000
      N  -1.366760000000  3.422020000000  0.012070000000
      H  -0.866230000000  4.276820000000 -0.181800000000
      H  -2.372570000000  3.427440000000 -0.024420000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
