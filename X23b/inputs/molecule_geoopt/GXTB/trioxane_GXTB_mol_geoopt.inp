&GLOBAL
  PRINT_LEVEL LOW
  PROJECT trioxane_GXTB_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -0.861500000000 -1.215750000000 -1.137680000000
      C   1.052970000000  0.090750000000 -1.137630000000
      C  -0.860370000000  0.837770000000 -0.062850000000
      H   2.135300000000  0.034560000000 -1.031190000000
      H  -1.220800000000 -0.773170000000 -2.084780000000
      H  -1.203520000000 -2.244240000000 -1.031910000000
      H  -1.201040000000  1.336850000000  0.843140000000
      H  -1.220280000000  1.364480000000 -0.965660000000
      H   0.772430000000  0.586530000000 -2.084990000000
      O   0.552310000000 -1.231510000000 -1.128840000000
      O   0.553550000000  0.838160000000 -0.046160000000
      O  -1.375420000000 -0.478850000000 -0.045830000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
