&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ethylcarbamate_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C   0.021660000000  0.206170000000  0.120830000000
      O   0.671140000000  1.223890000000  0.289340000000
      O   0.553580000000 -1.035330000000 -0.020990000000
      N  -1.342500000000  0.146990000000  0.074200000000
      H  -1.840000000000  1.020780000000  0.018450000000
      H  -1.801400000000 -0.700500000000 -0.219990000000
      C   1.997070000000 -1.113650000000  0.057480000000
      C   2.383910000000 -2.569590000000 -0.120820000000
      H   2.317370000000 -0.720760000000  1.027140000000
      H   2.426610000000 -0.477100000000 -0.721930000000
      H   3.473120000000 -2.668630000000 -0.066620000000
      H   1.942800000000 -3.192740000000  0.663110000000
      H   2.052670000000 -2.948820000000 -1.092440000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
