&GLOBAL
  PRINT_LEVEL LOW
  PROJECT pyrazole_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C  -0.304560000000 -2.011640000000 -0.000010000000
      C   1.078650000000 -2.014940000000  0.000070000000
      C   1.437300000000 -0.645380000000 -0.000070000000
      N  -0.679780000000 -0.704720000000 -0.000060000000
      H  -1.615600000000 -0.329510000000 -0.000130000000
      H  -1.028480000000 -2.813480000000  0.000010000000
      H   1.730790000000 -2.875430000000  0.000140000000
      H   2.426040000000 -0.207370000000 -0.000090000000
      N   0.366260000000  0.149480000000 -0.000010000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
