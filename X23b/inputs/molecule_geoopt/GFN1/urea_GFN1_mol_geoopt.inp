&GLOBAL
  PRINT_LEVEL LOW
  PROJECT urea_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
          ACCURACY 0.1
        &END TBLITE
      &END XTB
    &END QS
    &POISSON
      PERIODIC NONE
    &END POISSON
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL
    &COORD
      C   0.085600000000  0.243270000000  0.000190000000
      O   0.696920000000  1.304400000000 -0.005150000000
      N  -1.267010000000  0.155190000000 -0.288740000000
      H  -1.805100000000 -0.598500000000  0.115510000000
      H  -1.734560000000  1.050180000000 -0.317050000000
      N   0.689280000000 -0.969030000000  0.296110000000
      H   0.306410000000 -1.814930000000 -0.102700000000
      H   1.698240000000 -0.923710000000  0.318420000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &GEO_OPT
    OPTIMIZER BFGS
    MAX_ITER 200
  &END GEO_OPT
&END MOTION
