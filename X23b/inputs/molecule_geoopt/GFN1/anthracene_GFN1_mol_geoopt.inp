&GLOBAL
  PRINT_LEVEL LOW
  PROJECT anthracene_GFN1_mol_geoopt
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
