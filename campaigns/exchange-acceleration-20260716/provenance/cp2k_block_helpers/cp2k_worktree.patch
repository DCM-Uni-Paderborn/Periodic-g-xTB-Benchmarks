+      CPASSERT(SIZE(kmap%rotation_slot, 2) == SIZE(kmap%symops, 2))
+      CPASSERT(SIZE(full_block, 1) == SIZE(full_block, 2))
+      CPASSERT(SIZE(reduced_block, 1) == SIZE(full_block, 1))
