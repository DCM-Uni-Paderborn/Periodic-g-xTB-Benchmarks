&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Ar4_layer_gxtb_xz_k212
  RUN_TYPE ENERGY_FORCE
&END GLOBAL
&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID ON
      GAMMA_CENTERED T
      SCHEME MACDONALD 2 1 2 0.0 0.0 0.0
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.2600000000 18.0000000000 5.2600000000
      PERIODIC XZ
    &END CELL
    &COORD
      SCALED
      Ar 0.113000 0.501000 0.037000
      Ar 0.486000 0.523000 0.014000
      Ar 0.517000 0.532000 0.491000
      Ar 0.029000 0.468000 0.546000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
