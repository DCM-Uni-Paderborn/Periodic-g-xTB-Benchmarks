&GLOBAL
  PROJECT gxtb_water_cation_uks_222
  RUN_TYPE ENERGY_FORCE
  PRINT_LEVEL MEDIUM
&END GLOBAL
&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR ANALYTICAL
  &DFT
    CHARGE 1
    MULTIPLICITY 2
    UKS T
    &KPOINTS
      FULL_GRID ON
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 2 2 2
      SYMMETRY OFF
      VERBOSE T
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      METHOD XTB
      EPS_DEFAULT 1.0E-12
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 1.0
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 8.0 8.0 8.0
      PERIODIC XYZ
    &END CELL
    &COORD
      O  4.000000  4.000000  4.000000
      H  4.758602  4.000000  4.504284
      H  3.241398  4.000000  4.504284
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
