&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2O_stress_L80
  RUN_TYPE DEBUG
&END GLOBAL
&DEBUG
  DEBUG_FORCES F
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE_MIXER
          ITERATIONS 300
          SOLVER GVD
        &END TBLITE_MIXER
        &TBLITE
          ACCURACY 0.1
          METHOD GXTB
          &REFERENCE_CLI
            CHECK_ENERGY T
            CHECK_FORCES T
            CHECK_VIRIAL T
            ERROR_LIMIT 1.0E-5
            KEEP_FILES T
            PREFIX H2O_stress_L80_cli
            PROGRAM_NAME tblite
            STOP_ON_ERROR F
            WORK_DIRECTORY .
          &END REFERENCE_CLI
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 80 80 80
      PERIODIC XYZ
    &END CELL
    &COORD
      UNIT BOHR
      H  -2.2988205177250001E-002  0.0000000000000000  -1.7618895424609600
      H   1.6536950272314599       0.0000000000000000   0.60848805100320003
      O  -0.10273226709885000      0.0000000000000000   7.2662693557249997E-002
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
