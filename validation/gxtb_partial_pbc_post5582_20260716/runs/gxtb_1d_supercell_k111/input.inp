&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Ar4_chain_gxtb_x_supercell_k111
  RUN_TYPE ENERGY_FORCE
&END GLOBAL
&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID ON
      SCHEME MONKHORST-PACK 1 1 1
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 10.5200000000 18.0000000000 18.0000000000
      PERIODIC X
    &END CELL
    &COORD
      SCALED
      Ar 0.056500 0.501000 0.537000
      Ar 0.306500 0.523000 0.514000
      Ar 0.556500 0.501000 0.537000
      Ar 0.806500 0.523000 0.514000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
