&GLOBAL
  PRINT_LEVEL LOW
  PROJECT nh3_k222_spglib_fd
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  CHECK_ATOM_FORCE 1 X
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 1.0
        &END TBLITE
      &END XTB
    &END QS
    &KPOINTS
      SCHEME MACDONALD 2 2 2 0.25 0.25 0.25
      EPS_SYMMETRY 1.0E-8
      VERBOSE T
      SYMMETRY T
      FULL_GRID F
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
    &END KPOINTS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      CANONICALIZE TRUE
      PERIODIC XYZ
      A 5.130500000000 0.000000000000 0.000000000000
      B 0.000000000000 5.130500000000 0.000000000000
      C 0.000000000000 0.000000000000 5.130500000000
    &END CELL
    &COORD
      SCALED
      N   0.210700000000  0.210700000000  0.210700000000
      N   0.710700000000  0.289300000000  0.789300000000
      N   0.789300000000  0.710700000000  0.289300000000
      N   0.289300000000  0.789300000000  0.710700000000
      H   0.368900000000  0.267100000000  0.115900000000
      H   0.868900000000  0.232900000000  0.884100000000
      H   0.115900000000  0.368900000000  0.267100000000
      H   0.884100000000  0.868900000000  0.232900000000
      H   0.267100000000  0.115900000000  0.368900000000
      H   0.232900000000  0.884100000000  0.868900000000
      H   0.767100000000  0.384100000000  0.631100000000
      H   0.732900000000  0.615900000000  0.131100000000
      H   0.615900000000  0.131100000000  0.732900000000
      H   0.384100000000  0.631100000000  0.767100000000
      H   0.631100000000  0.767100000000  0.384100000000
      H   0.131100000000  0.732900000000  0.615900000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
