&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Ar2_chain_gxtb_x_k211
  RUN_TYPE ENERGY_FORCE
&END GLOBAL
&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID ON
      SCHEME MONKHORST-PACK 2 1 1
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
    &STRESS_TENSOR ON
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 5.2600000000 18.0000000000 18.0000000000
      PERIODIC X
    &END CELL
    &COORD
      SCALED
      Ar 0.113000 0.501000 0.537000
      Ar 0.613000 0.523000 0.514000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
