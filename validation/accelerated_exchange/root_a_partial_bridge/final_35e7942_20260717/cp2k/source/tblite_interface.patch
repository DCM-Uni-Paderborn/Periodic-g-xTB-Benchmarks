+!> \param leader ...
+!> \param service_rank ...
+!> \param para_env_inter_kp ...
+!> \param para_env_kp ...
+!> \param transaction_id ...
+! **************************************************************************************************
+   SUBROUTINE tb_gxtb_partial_next_transaction(leader, service_rank, para_env_inter_kp, &
+                                               para_env_kp, transaction_id)
+
+      LOGICAL, INTENT(IN)                                :: leader, service_rank
+      TYPE(mp_para_env_type), POINTER                    :: para_env_inter_kp, para_env_kp
+      INTEGER(KIND=int_8), DIMENSION(2), INTENT(OUT)     :: transaction_id
+
+      LOGICAL                                            :: local_failed
+
+      transaction_id = 0_int_8
+      local_failed = .FALSE.
+      IF (service_rank) THEN
+         local_failed = tb_gxtb_partial_transaction_serial == HUGE(0_int_8)
+         IF (.NOT. local_failed) &
+            tb_gxtb_partial_transaction_serial = tb_gxtb_partial_transaction_serial + 1_int_8
+      END IF
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "g-xTB partial transaction identity overflow")
+      IF (leader) THEN
+         IF (service_rank) transaction_id = &
+            [2718281828459045_int_8, tb_gxtb_partial_transaction_serial]
+         CALL para_env_inter_kp%bcast(transaction_id)
+      END IF
+
+   END SUBROUTINE tb_gxtb_partial_next_transaction
