+! **************************************************************************************************
+!> \brief Compare the complete canonical provider descriptor on every k-group leader.
+!> \param leader ...
+!> \param service_rank ...
+!> \param descriptor ...
+!> \param para_env_inter_kp ...
+!> \param para_env_kp ...
+! **************************************************************************************************
+   SUBROUTINE tb_gxtb_partial_descriptor_consensus(leader, service_rank, descriptor, &
+                                                   para_env_inter_kp, para_env_kp)
+
+      LOGICAL, INTENT(IN)                                :: leader, service_rank
+      TYPE(cp2k_exchange_partial_descriptor_type), &
+         INTENT(IN)                                      :: descriptor
+      TYPE(mp_para_env_type), POINTER                    :: para_env_inter_kp, para_env_kp
+
+      INTEGER(KIND=int_8), ALLOCATABLE, DIMENSION(:)     :: local_words, root_words
+      LOGICAL                                            :: local_failed
+      TYPE(cp2k_exchange_partial_descriptor_type)        :: root_descriptor
+      TYPE(error_type), ALLOCATABLE                      :: error
+
+      local_failed = .FALSE.
+      IF (leader) THEN
+         CALL cp2k_exchange_partial_descriptor_pack(descriptor, local_words, error)
+         local_failed = ALLOCATED(error)
+         IF (.NOT. local_failed) local_failed = &
+            INT(SIZE(local_words), int_8) /= cp2k_exchange_partial_descriptor_size()
+      END IF
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "save_tblite partial descriptor packing failed")
+
+      IF (leader) THEN
+         ALLOCATE (root_words(SIZE(local_words)), source=0_int_8)
+         IF (service_rank) root_words(:) = local_words
+         CALL para_env_inter_kp%bcast(root_words)
+         CALL cp2k_exchange_partial_descriptor_unpack(root_descriptor, root_words, error)
+         local_failed = ALLOCATED(error)
+         IF (.NOT. local_failed) local_failed = &
+            .NOT. cp2k_exchange_partial_descriptors_match(descriptor, root_descriptor)
+      ELSE
+         local_failed = .FALSE.
+      END IF
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "save_tblite partial descriptor consensus failed")
+      IF (leader) DEALLOCATE (local_words, root_words)
+
+   END SUBROUTINE tb_gxtb_partial_descriptor_consensus
