+! **************************************************************************************************
+!> \brief Propagate a partial-exchange stage failure without stranding ranks in collectives.
+!>
+!> Only k-group leaders participate in the inter-group communicator that owns
+!> the partial transaction.  The resulting status is then broadcast inside
+!> every official CP2K k group so leaders and nonleaders abort at the same
+!> protocol boundary.
+!> \param leader ...
+!> \param para_env_inter_kp ...
+!> \param para_env_kp ...
+!> \param local_failed ...
+!> \param message ...
+! **************************************************************************************************
+   SUBROUTINE tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, message)
+
+      LOGICAL, INTENT(IN)                                :: leader
+      TYPE(mp_para_env_type), POINTER                    :: para_env_inter_kp, para_env_kp
+      LOGICAL, INTENT(IN)                                :: local_failed
+      CHARACTER(LEN=*), INTENT(IN)                       :: message
+
+      INTEGER                                            :: failure_count
+
+      failure_count = MERGE(1, 0, local_failed)
+      CALL para_env_kp%sum(failure_count)
+      IF (leader) CALL para_env_inter_kp%sum(failure_count)
+      CALL para_env_kp%bcast(failure_count)
+      IF (failure_count /= 0) CPABORT(message)
+
+   END SUBROUTINE tb_gxtb_partial_sync_failure
+
+! **************************************************************************************************
