+! **************************************************************************************************
+!> \brief Reduce an arbitrarily long packed complex payload to the service leader.
+!>
+!> CP2K's MPI wrappers intentionally use a default-integer MPI count.  Fixed
+!> chunks keep every call below that bound even though the provider reports
+!> payload sizes with INT64.
+!> \param values ...
+!> \param para_env_inter_kp ...
+! **************************************************************************************************
+   SUBROUTINE tb_gxtb_partial_reduce_complex_root(values, para_env_inter_kp)
+
+      COMPLEX(KIND=dp), CONTIGUOUS, DIMENSION(:), &
+         INTENT(INOUT)                                   :: values
+      TYPE(mp_para_env_type), POINTER                    :: para_env_inter_kp
+
+      INTEGER(KIND=int_8), PARAMETER                     :: chunk_size = 1048576_int_8
+
+      INTEGER(KIND=int_8)                                :: first, last, nelements
+
+      nelements = SIZE(values, KIND=int_8)
+      first = 1_int_8
+      DO WHILE (first <= nelements)
+         last = MIN(nelements, first + chunk_size - 1_int_8)
+         CALL para_env_inter_kp%sum(values(first:last), para_env_inter_kp%source)
+         first = last + 1_int_8
+      END DO
+
+   END SUBROUTINE tb_gxtb_partial_reduce_complex_root
