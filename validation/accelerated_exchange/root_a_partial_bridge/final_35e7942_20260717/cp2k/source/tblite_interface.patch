+      IF (.NOT. ALL(ieee_is_finite(tb%wfn%qsh))) &
+         CPABORT("CP2K supplied non-finite shell charges to KGROUP_PARTIAL_ROOT")
+
+      density_norm = MAXVAL(ABS(density_local))
+      CALL para_env_global%max(density_norm)
+      validate_density = .NOT. kmap%identity .AND. &
+                         .NOT. tb%gxtb_density_map_validated .AND. &
+                         density_norm > 1.0E-14_dp
+      exchange_energy = 0.0_dp
+      exchange_vsh = 0.0_dp
+      ALLOCATE (tb%exchange_fock_kp(nao, nao, nspin, nred), &
+                source=CMPLX(0.0_dp, 0.0_dp, KIND=dp))
+
+      ALLOCATE (rmatrix, cmatrix)
+      CALL dbcsr_create(rmatrix, template=matrix_s(1, 1)%matrix, &
+                        matrix_type=dbcsr_type_symmetric)
+      CALL dbcsr_create(cmatrix, template=matrix_s(1, 1)%matrix, &
+                        matrix_type=dbcsr_type_antisymmetric)
+      CALL cp_dbcsr_alloc_block_from_nbl(rmatrix, sab_nl)
+      CALL cp_dbcsr_alloc_block_from_nbl(cmatrix, sab_nl)
+
+      batch_size = tb_gxtb_exchange_stream_batch_size()
+      actual_batch_size = MIN(batch_size, kmap%nfull)
+      CALL tb_gxtb_partial_next_transaction(leader, service_rank, para_env_inter_kp, &
+                                            para_env_kp, transaction_id)
+      local_failed = .FALSE.
+      IF (leader) THEN
+         CALL cp2k_exchange_partial_begin(stream, tb%calc, tb%mol, tb%ecache, tb%wfn, &
+                                          kmap%nmesh, kmap%xkp, kmap%weight, batch_size, &
+                                          transaction_id, error)
+         local_failed = ALLOCATED(error)
+      ELSE
+         CALL cp2k_prepare_exchange(tb%calc, tb%mol, tb%ecache, tb%wfn, error)
+         local_failed = ALLOCATED(error)
+      END IF
+      IF (injection_mode == tb_gxtb_partial_inject_nonleader_failure .AND. .NOT. leader) &
+         local_failed = .TRUE.
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "save_tblite KGROUP_PARTIAL_ROOT initialization failed")
+
+      batch_done = .FALSE.
+      first_batch = .TRUE.
+      DO WHILE (.NOT. batch_done)
+         local_failed = .FALSE.
+         DO ifull = 1, kmap%nfull
+            source = kmap%source(ifull)
+            owns_source = source >= kp_range(1) .AND. source <= kp_range(2)
+            CALL prepare_overlap_block(ifull)
+            IF (leader .AND. owns_source .AND. .NOT. local_failed) THEN
+               local_source = source - kp_range(1) + 1
+               DO ispin = 1, nspin
+                  CALL tb_expand_gxtb_kpoint_block( &
+                     kpoints, kmap, ao_first, ao_size, ifull, &
+                     density_local(:, :, ispin, local_source), &
+                     density_block(:, :, ispin), transform_work)
+                  IF (validate_density .AND. first_batch) THEN
+                     DO iop = 1, kmap%op_count(ifull)
+                        CALL tb_transform_gxtb_kpoint_matrix( &
+                           kpoints, source, kmap%symops(iop, ifull), &
+                           kmap%rotation_slot(iop, ifull), ao_first, ao_size, &
+                           density_local(:, :, ispin, local_source), &
+                           transform_work, .FALSE.)
+                        scale = MAX(1.0_dp, MAXVAL(ABS(density_block(:, :, ispin))))
+                        residual = MAXVAL(ABS(transform_work - density_block(:, :, ispin)))/scale
+                        IF (residual > MAX(1.0E-10_dp, 100.0_dp*kpoints%eps_geo)) &
+                           CPABORT("KGROUP_PARTIAL_ROOT density violates its little group")
+                     END DO
+                  END IF
+               END DO
+               CALL cp2k_exchange_partial_push(stream, ifull, density_block, &
+                                               overlap_block, error)
+               local_failed = ALLOCATED(error)
+            END IF
+         END DO
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT push failed")
+         IF (validate_density .AND. first_batch) tb%gxtb_density_map_validated = .TRUE.
+
+         IF (leader) THEN
+            CALL cp2k_exchange_partial_export_forward(stream, descriptor, owner_count, &
+                                                      local_buffer, error)
+            local_failed = ALLOCATED(error)
+         ELSE
+            local_failed = .FALSE.
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT export failed")
+         CALL tb_gxtb_partial_descriptor_consensus(leader, service_rank, descriptor, &
+                                                   para_env_inter_kp, para_env_kp)
+
+         IF (leader) THEN
+            local_payload_size = cp2k_exchange_partial_forward_size(local_buffer)
+            root_payload_size = MERGE(local_payload_size, 0_int_8, service_rank)
+            CALL para_env_inter_kp%bcast(root_payload_size)
+            local_failed = local_payload_size /= root_payload_size .OR. &
+                           local_payload_size < 0_int_8
+         ELSE
+            local_failed = .FALSE.
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "Inconsistent KGROUP_PARTIAL_ROOT payload size")
+
+         IF (leader) THEN
+            CALL cp2k_exchange_partial_forward_pack(local_buffer, packed_payload, error)
+            local_failed = ALLOCATED(error)
+            IF (.NOT. local_failed) local_failed = &
+               SIZE(packed_payload, KIND=int_8) /= root_payload_size
+         ELSE
+            local_failed = .FALSE.
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT packing failed")
+
+         IF (leader) THEN
+            ALLOCATE (owner_sum, source=owner_count)
+            CALL para_env_inter_kp%sum(owner_sum, para_env_inter_kp%source)
+            CALL tb_gxtb_partial_reduce_complex_root(packed_payload, para_env_inter_kp)
+            local_failed = .FALSE.
+            IF (service_rank) local_failed = ANY(owner_sum /= 1) .OR. &
+                                             .NOT. ALL(ieee_is_finite(REAL(packed_payload, KIND=dp))) .OR. &
+                                             .NOT. ALL(ieee_is_finite(AIMAG(packed_payload)))
+         ELSE
+            local_failed = .FALSE.
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "Invalid KGROUP_PARTIAL_ROOT ownership or payload")
+
+         local_failed = .FALSE.
+         IF (service_rank) THEN
+            CALL cp2k_exchange_partial_forward_unpack(summed_buffer, descriptor, &
+                                                      packed_payload, error)
+            local_failed = ALLOCATED(error)
+            IF (.NOT. local_failed) THEN
+               CALL cp2k_exchange_partial_import_forward(stream, descriptor, owner_sum, &
+                                                         summed_buffer, tb%calc, tb%mol, &
+                                                         tb%ecache, error)
+               local_failed = ALLOCATED(error)
+            END IF
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT import failed")
+
+         local_failed = .FALSE.
+         IF (service_rank) THEN
+            CALL cp2k_exchange_stream_batch_apply(stream, tb%calc, tb%mol, tb%ecache, error)
+            local_failed = ALLOCATED(error)
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT apply failed")
+
+         DO ifull = 1, kmap%nfull
+            source = kmap%source(ifull)
+            owns_source = source >= kp_range(1) .AND. source <= kp_range(2)
+            CALL prepare_overlap_block(ifull)
+            fock_batch = CMPLX(0.0_dp, 0.0_dp, KIND=dp)
+            local_failed = .FALSE.
+            IF (service_rank) THEN
+               CALL cp2k_exchange_stream_batch_pull(stream, ifull, overlap_block, &
+                                                    fock_batch, error)
+               local_failed = ALLOCATED(error)
+               IF (.NOT. local_failed) local_failed = &
+                  .NOT. ALL(ieee_is_finite(REAL(fock_batch, KIND=dp))) .OR. &
+                  .NOT. ALL(ieee_is_finite(AIMAG(fock_batch)))
+            END IF
+            CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                              local_failed, &
+                                              "save_tblite KGROUP_PARTIAL_ROOT pull failed")
+            IF (leader) CALL para_env_inter_kp%bcast(fock_batch)
+            IF (leader .AND. owns_source) THEN
+               DO ispin = 1, nspin
+                  CALL tb_accumulate_gxtb_kpoint_response( &
+                     kpoints, kmap, ao_first, ao_size, ifull, fock_batch(:, :, ispin), &
+                     tb%exchange_fock_kp(:, :, ispin, source), transform_work)
+               END DO
+            END IF
+         END DO
+
+         contributor_done = .FALSE.
+         local_failed = .FALSE.
+         IF (service_rank) THEN
+            CALL cp2k_exchange_stream_batch_advance(stream, contributor_done, error)
+            local_failed = ALLOCATED(error)
+         ELSE IF (leader) THEN
+            CALL cp2k_exchange_partial_contributor_advance(stream, contributor_done, error)
+            local_failed = ALLOCATED(error)
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "save_tblite KGROUP_PARTIAL_ROOT advance failed")
+         done_count = 0
+         IF (leader) THEN
+            done_count = MERGE(1, 0, contributor_done)
+            CALL para_env_inter_kp%sum(done_count)
+            local_failed = done_count /= 0 .AND. done_count /= nkp_groups
+         ELSE
+            local_failed = .FALSE.
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "KGROUP_PARTIAL_ROOT generations diverged")
+         CALL para_env_kp%bcast(done_count)
+         batch_done = done_count == nkp_groups
+         first_batch = .FALSE.
+         IF (leader) THEN
+            DEALLOCATE (owner_count, owner_sum, packed_payload)
+         END IF
+      END DO
+
+      local_failed = .FALSE.
+      IF (service_rank) THEN
+         CALL cp2k_exchange_stream_batch_result(stream, tb%calc, tb%mol, tb%ecache, &
+                                                exchange_vsh, exchange_energy, error)
+         local_failed = ALLOCATED(error)
+         IF (injection_mode == tb_gxtb_partial_inject_nonfinite_forward_result) &
+            exchange_energy = ieee_value(exchange_energy, ieee_quiet_nan)
+         IF (.NOT. local_failed) local_failed = &
+            .NOT. ieee_is_finite(exchange_energy) .OR. &
+            .NOT. ALL(ieee_is_finite(exchange_vsh))
+      END IF
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "save_tblite KGROUP_PARTIAL_ROOT result failed")
+      IF (service_rank) THEN
+         CALL cp2k_exchange_stream_end(stream, error)
+      ELSE IF (leader) THEN
+         CALL cp2k_exchange_partial_discard(stream, error)
+      END IF
+      local_failed = leader .AND. ALLOCATED(error)
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "save_tblite KGROUP_PARTIAL_ROOT finalization failed")
+
+      IF (leader) THEN
+         CALL para_env_inter_kp%bcast(exchange_energy)
+         CALL para_env_inter_kp%bcast(exchange_vsh)
+         CALL para_env_inter_kp%sum(tb%exchange_fock_kp)
+      END IF
+      CALL para_env_kp%sum(exchange_energy)
+      CALL para_env_kp%sum(exchange_vsh)
+      CALL para_env_kp%sum(tb%exchange_fock_kp)
+      local_failed = .NOT. ALL(ieee_is_finite(REAL(tb%exchange_fock_kp, KIND=dp))) .OR. &
+                     .NOT. ALL(ieee_is_finite(AIMAG(tb%exchange_fock_kp)))
+      CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                        local_failed, &
+                                        "Non-finite folded KGROUP_PARTIAL_ROOT Fock response")
+      DO source = 1, nred
+         DO ispin = 1, nspin
+            hermitian_error = &
+               MAXVAL(ABS(tb%exchange_fock_kp(:, :, ispin, source) - &
+                          CONJG(TRANSPOSE(tb%exchange_fock_kp(:, :, ispin, source)))))
+            IF (hermitian_error > 1.0E-10_dp) &
+               CPABORT("Folded KGROUP_PARTIAL_ROOT Fock matrix is not Hermitian")
+            tb%exchange_fock_kp(:, :, ispin, source) = &
+               0.5_dp*(tb%exchange_fock_kp(:, :, ispin, source) + &
+                       CONJG(TRANSPOSE(tb%exchange_fock_kp(:, :, ispin, source))))
+         END DO
+         IF (use_real_wfn .AND. &
+             MAXVAL(ABS(AIMAG(tb%exchange_fock_kp(:, :, :, source)))) > 1.0E-10_dp) &
+            CPABORT("Complex KGROUP_PARTIAL_ROOT Fock cannot use real wavefunctions")
+      END DO
+
+      tb%e_exchange = 0.0_dp
+      tb%e_exchange(1) = exchange_energy
+      tb%pot%vsh(:, 1) = tb%pot%vsh(:, 1) + exchange_vsh
+      tb%exchange_fock_kp_valid = .TRUE.
+      IF (run_qualification_oracle) CALL qualify_partial_root_oracle()
+      IF (service_rank .AND. iter_count == 1) THEN
+         WRITE (*, '(A,I0,A,I0,A,I0,A,I0,A)') &
+            " GXTB-KGROUP-PARTIAL-ROOT groups=", nkp_groups, ", nred=", nred, &
+            ", nfull=", kmap%nfull, ", batch=", actual_batch_size, &
+            "; only pre-kernel k-to-R is distributed"
+      END IF
+
+      CALL dbcsr_deallocate_matrix(rmatrix)
+      CALL dbcsr_deallocate_matrix(cmatrix)
+      DEALLOCATE (ao_first, ao_size, density_block, density_local, exchange_vsh, &
+                  fock_batch, overlap_block, overlap_part, transform_work)
+
+   CONTAINS
+
+! **************************************************************************************************
+!> \brief ...
+!> \param ifull_local ...
+! **************************************************************************************************
+      SUBROUTINE prepare_overlap_block(ifull_local)
+
+      INTEGER, INTENT(IN)                                :: ifull_local
+
+      REAL(KIND=dp)                                      :: local_hermitian_error
+
+         CALL dbcsr_set(rmatrix, 0.0_dp)
+         CALL dbcsr_set(cmatrix, 0.0_dp)
+         CALL rskp_transform(rmatrix, cmatrix, matrix_s, 1, kmap%xkp(1:3, ifull_local), &
+                             cell_to_index, sab_nl)
+         CALL tb_dbcsr_component_to_dense(tb, rmatrix, overlap_part, para_env_global, .FALSE.)
+         overlap_block(:, :) = CMPLX(overlap_part, 0.0_dp, KIND=dp)
+         CALL tb_dbcsr_component_to_dense(tb, cmatrix, overlap_part, para_env_global, .TRUE.)
+         overlap_block(:, :) = CMPLX(REAL(overlap_block, KIND=dp), overlap_part, KIND=dp)
+         IF (.NOT. ALL(ieee_is_finite(REAL(overlap_block, KIND=dp))) .OR. &
+             .NOT. ALL(ieee_is_finite(AIMAG(overlap_block)))) &
+            CPABORT("CP2K supplied a non-finite KGROUP_PARTIAL_ROOT overlap")
+         local_hermitian_error = &
+            MAXVAL(ABS(overlap_block - CONJG(TRANSPOSE(overlap_block))))
+         IF (local_hermitian_error > 1.0E-10_dp) &
+            CPABORT("CP2K supplied a non-Hermitian KGROUP_PARTIAL_ROOT overlap")
+
+      END SUBROUTINE prepare_overlap_block
+
+! **************************************************************************************************
+!> \brief ...
+! **************************************************************************************************
+      SUBROUTINE qualify_partial_root_oracle()
+
+      COMPLEX(KIND=dp), ALLOCATABLE, DIMENSION(:, :, :)  :: overlap_full
+      COMPLEX(KIND=dp), ALLOCATABLE, &
+         DIMENSION(:, :, :, :)                           :: density_full, fock_full, &
+                                                            fock_reduced_oracle
+      INTEGER                                            :: ifull_local, ispin_local, &
+                                                            local_source_local, source_local
+      REAL(KIND=dp)                                      :: energy_delta, energy_oracle, fock_delta, &
+                                                            vsh_delta
+      REAL(KIND=dp), ALLOCATABLE, DIMENSION(:)           :: vsh_oracle
+
+         IF (service_rank) THEN
+            ALLOCATE (density_full(nao, nao, nspin, kmap%nfull), &
+                      fock_full(nao, nao, nspin, kmap%nfull), &
+                      fock_reduced_oracle(nao, nao, nspin, nred), &
+                      overlap_full(nao, nao, kmap%nfull), &
+                      source=CMPLX(0.0_dp, 0.0_dp, KIND=dp))
+            ALLOCATE (vsh_oracle(SIZE(exchange_vsh)), source=0.0_dp)
+         END IF
+         DO ifull_local = 1, kmap%nfull
+            source_local = kmap%source(ifull_local)
+            owns_source = source_local >= kp_range(1) .AND. source_local <= kp_range(2)
+            density_block = CMPLX(0.0_dp, 0.0_dp, KIND=dp)
+            IF (leader .AND. owns_source) THEN
+               local_source_local = source_local - kp_range(1) + 1
+               DO ispin_local = 1, nspin
+                  CALL tb_expand_gxtb_kpoint_block( &
+                     kpoints, kmap, ao_first, ao_size, ifull_local, &
+                     density_local(:, :, ispin_local, local_source_local), &
+                     density_block(:, :, ispin_local), transform_work)
+               END DO
+            END IF
+            IF (leader) CALL para_env_inter_kp%sum(density_block)
+            CALL para_env_kp%sum(density_block)
+            CALL prepare_overlap_block(ifull_local)
+            IF (service_rank) THEN
+               density_full(:, :, :, ifull_local) = density_block
+               overlap_full(:, :, ifull_local) = overlap_block
+            END IF
+         END DO
+         local_failed = .FALSE.
+         IF (service_rank) THEN
+            CALL cp2k_exchange_kmesh(tb%calc, tb%mol, tb%ecache, tb%wfn, kmap%nmesh, &
+                                     kmap%xkp, kmap%weight, density_full, overlap_full, &
+                                     fock_full, vsh_oracle, energy_oracle, error, &
+                                     transform_backend=cp2k_exchange_transform_dense)
+            local_failed = ALLOCATED(error)
+            IF (.NOT. local_failed) local_failed = &
+               .NOT. ieee_is_finite(energy_oracle) .OR. &
+               .NOT. ALL(ieee_is_finite(vsh_oracle)) .OR. &
+               .NOT. ALL(ieee_is_finite(REAL(fock_full, KIND=dp))) .OR. &
+               .NOT. ALL(ieee_is_finite(AIMAG(fock_full)))
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "KGROUP_PARTIAL_ROOT dense forward oracle failed")
+         local_failed = .FALSE.
+         IF (service_rank) THEN
+            fock_reduced_oracle = CMPLX(0.0_dp, 0.0_dp, KIND=dp)
+            DO ispin_local = 1, nspin
+               CALL tb_fold_gxtb_kpoint_matrix( &
+                  kpoints, kmap, ao_first, ao_size, fock_full(:, :, ispin_local, :), &
+                  fock_reduced_oracle(:, :, ispin_local, :))
+            END DO
+            energy_delta = ABS(exchange_energy - energy_oracle)
+            vsh_delta = MAXVAL(ABS(exchange_vsh - vsh_oracle))
+            fock_delta = MAXVAL(ABS(tb%exchange_fock_kp - fock_reduced_oracle))
+            WRITE (*, '(A,I0,3(A,ES14.6))') &
+               " GXTB-QUALIFICATION_ONLY KGROUP-PARTIAL-ROOT iter=", iter_count, &
+               " dE=", energy_delta, " dVsh=", vsh_delta, " dFfold=", fock_delta
+            local_failed = &
+               .NOT. ALL(ieee_is_finite(REAL(fock_reduced_oracle, KIND=dp))) .OR. &
+               .NOT. ALL(ieee_is_finite(AIMAG(fock_reduced_oracle))) .OR. &
+               .NOT. ieee_is_finite(energy_delta) .OR. &
+               .NOT. ieee_is_finite(vsh_delta) .OR. &
+               .NOT. ieee_is_finite(fock_delta) .OR. &
+               energy_delta > 1.0E-10_dp .OR. vsh_delta > 1.0E-10_dp .OR. &
+               fock_delta > 1.0E-10_dp
+         END IF
+         CALL tb_gxtb_partial_sync_failure(leader, para_env_inter_kp, para_env_kp, &
+                                           local_failed, &
+                                           "KGROUP_PARTIAL_ROOT dense oracle exceeded 1.0E-10")
+         IF (service_rank) &
+            DEALLOCATE (density_full, fock_full, fock_reduced_oracle, overlap_full, vsh_oracle)
+
+      END SUBROUTINE qualify_partial_root_oracle
+
