 ! **************************************************************************************************
+!> \brief Select a strictly qualification-only partial-bridge fault injection.
+!>
+!> Normal calculations do not inspect the environment variable.  Qualification
+!> runs accept only the explicit whitelist below, so misspelled test selectors
+!> fail closed rather than silently weakening a negative test.
+!> \param enabled ...
+!> \return injection_mode ...
+! **************************************************************************************************
+   INTEGER FUNCTION tb_gxtb_partial_qualification_injection(enabled) RESULT(injection_mode)
+
+      LOGICAL, INTENT(IN)                                :: enabled
+
+      CHARACTER(LEN=64)                                  :: value
+      INTEGER                                            :: status
+
+      injection_mode = tb_gxtb_partial_inject_none
+      IF (.NOT. enabled) RETURN
+      value = ""
+      status = 1
+      CALL GET_ENVIRONMENT_VARIABLE("CP2K_GXTB_PARTIAL_QUALIFY_INJECT", value, STATUS=status)
+      SELECT CASE (status)
+      CASE (1)
+         RETURN
+      CASE (0)
+         IF (LEN_TRIM(value) == 0) RETURN
+      CASE DEFAULT
+         CPABORT("CP2K_GXTB_PARTIAL_QUALIFY_INJECT is truncated or unreadable")
+      END SELECT
+
+      SELECT CASE (TRIM(ADJUSTL(value)))
+      CASE ("NONLEADER_FAILURE", "nonleader_failure")
+         injection_mode = tb_gxtb_partial_inject_nonleader_failure
+      CASE ("ANTIHERMITIAN_REVERSE", "antihermitian_reverse")
+         injection_mode = tb_gxtb_partial_inject_antihermitian_reverse
+      CASE ("NONFINITE_FORWARD_RESULT", "nonfinite_forward_result")
+         injection_mode = tb_gxtb_partial_inject_nonfinite_forward_result
+      CASE DEFAULT
+         CPABORT("Unknown CP2K_GXTB_PARTIAL_QUALIFY_INJECT value")
+      END SELECT
+
+   END FUNCTION tb_gxtb_partial_qualification_injection
