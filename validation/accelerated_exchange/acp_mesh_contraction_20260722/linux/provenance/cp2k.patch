+! **************************************************************************************************
+!> \brief Return the largest componentwise relative ACP derivative residual.
+! **************************************************************************************************
+   REAL(KIND=dp) FUNCTION tb_gxtb_acp_gradient_residual( &
+      dEdcnbas, dEdqbas, gradient, sigma, &
+      reference_dEdcnbas, reference_dEdqbas, reference_gradient, reference_sigma) RESULT(residual)
+
+      REAL(KIND=dp), DIMENSION(:), INTENT(IN)            :: dEdcnbas, dEdqbas
+      REAL(KIND=dp), DIMENSION(:, :), INTENT(IN)         :: gradient, sigma
+      REAL(KIND=dp), DIMENSION(:), INTENT(IN)            :: reference_dEdcnbas, reference_dEdqbas
+      REAL(KIND=dp), DIMENSION(:, :), INTENT(IN)         :: reference_gradient, reference_sigma
+
+      REAL(KIND=dp)                                      :: scale
+
+      residual = 0.0_dp
+      scale = MAX(1.0_dp, MAXVAL(ABS(reference_dEdcnbas)))
+      residual = MAX(residual, MAXVAL(ABS(dEdcnbas - reference_dEdcnbas))/scale)
+      scale = MAX(1.0_dp, MAXVAL(ABS(reference_dEdqbas)))
+      residual = MAX(residual, MAXVAL(ABS(dEdqbas - reference_dEdqbas))/scale)
+      scale = MAX(1.0_dp, MAXVAL(ABS(reference_gradient)))
+      residual = MAX(residual, MAXVAL(ABS(gradient - reference_gradient))/scale)
+      scale = MAX(1.0_dp, MAXVAL(ABS(reference_sigma)))
+      residual = MAX(residual, MAXVAL(ABS(sigma - reference_sigma))/scale)
+
+   END FUNCTION tb_gxtb_acp_gradient_residual
