+      value_length = 0
+      value = ""
+      CALL GET_ENVIRONMENT_VARIABLE("CP2K_GXTB_ACP_MESH_CONTRACTION", value, &
+                                    LENGTH=value_length, STATUS=status)
+      IF (status == 1 .AND. value_length == 0) RETURN
+      IF (status /= 0 .OR. value_length > LEN(value)) THEN
+         CPABORT("Invalid or overlong CP2K_GXTB_ACP_MESH_CONTRACTION value")
+      END IF
+      IF (LEN_TRIM(value) == 0) THEN
+         CPABORT("CP2K_GXTB_ACP_MESH_CONTRACTION must not be empty")
+      END IF
+
+      SELECT CASE (TRIM(ADJUSTL(value)))
+      CASE ("DENSE", "dense", "0")
+         mesh_mode = tb_gxtb_acp_mesh_dense
+      CASE ("STREAMED", "streamed", "BATCHED", "batched", "1")
+         mesh_mode = tb_gxtb_acp_mesh_streamed
+      CASE ("QUALIFY", "qualify", "ORACLE", "oracle", "2")
+         mesh_mode = tb_gxtb_acp_mesh_qualify
+      CASE DEFAULT
+         CPABORT("Unknown CP2K_GXTB_ACP_MESH_CONTRACTION value")
+      END SELECT
+
