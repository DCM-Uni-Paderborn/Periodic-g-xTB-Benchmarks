+            CALL tb_gxtb_acp_streamed_gradient( &
+               tb, projector_translations, translations, density_images, &
+               dEdcnbas, dEdqbas, acp_gradient, acp_sigma, &
+               prepared_images=acp_qualification_images)
+            scale = MAX(1.0_dp, MAXVAL(ABS(oracle_dEdcnbas)))
+            acp_cn_residual = MAXVAL(ABS(dEdcnbas - oracle_dEdcnbas))/scale
+            scale = MAX(1.0_dp, MAXVAL(ABS(oracle_dEdqbas)))
+            acp_q_residual = MAXVAL(ABS(dEdqbas - oracle_dEdqbas))/scale
+            scale = MAX(1.0_dp, MAXVAL(ABS(acp_oracle_gradient)))
+            acp_gradient_residual = MAXVAL(ABS(acp_gradient - acp_oracle_gradient))/scale
+            scale = MAX(1.0_dp, MAXVAL(ABS(acp_oracle_sigma)))
+            acp_sigma_residual = MAXVAL(ABS(acp_sigma - acp_oracle_sigma))/scale
+            acp_residual = tb_gxtb_acp_gradient_residual( &
