From 331757ad2d4ac814521911a620bc724ad753bc57 Mon Sep 17 00:00:00 2001
From: "Thomas D. Kuehne" <tkuehne@cp2k.org>
Date: Wed, 22 Jul 2026 16:29:30 +0200
Subject: [PATCH 1/2] Fix ACP response orientation for complex meshes
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: Thomas D. Kühne <tkuehne@cp2k.org>
---
 src/tblite/acp/type.f90 | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

diff --git a/src/tblite/acp/type.f90 b/src/tblite/acp/type.f90
index 2e2af03..1f055d4 100644
--- a/src/tblite/acp/type.f90
+++ b/src/tblite/acp/type.f90
@@ -991,6 +991,12 @@ end subroutine clear_acp_kmesh_gradient_stream
 
 !> Differentiate compact ACP projector images against sparse density images.
 !>
+!> The density-cell labels follow CP2K's real-space transform.  For the
+!> projector response at `U`, the two ordered ACP legs therefore contribute
+!> `L C_V P_(U-V)` and `L C_V P_(V-U)^T`.  Keeping this orientation explicit
+!> is essential for genuinely complex meshes; self-inverse meshes cannot
+!> expose an accidental `R`/`-R` interchange.
+!>
 !> Missing translation differences are treated as exact zero-density blocks.
 !> Unlike `get_acp_image_gradient`, neither the quadratic Hamiltonian
 !> difference set nor a zero-padded density array is required.
@@ -1063,7 +1069,7 @@ subroutine get_acp_projector_image_gradient(mol, bas, bcache, acp, acache, &
             do spin = 1, nspin
                call gemm(amat=images%scaled_projector_overlap(:, :, jtr), &
                   & bmat=density(:, :, dtr, spin), &
-                  & cmat=response(:, :, itr, spin), transb='T', beta=1.0_wp)
+                  & cmat=response(:, :, itr, spin), beta=1.0_wp)
             end do
          end if
 
@@ -1073,7 +1079,7 @@ subroutine get_acp_projector_image_gradient(mol, bas, bcache, acp, acache, &
             do spin = 1, nspin
                call gemm(amat=images%scaled_projector_overlap(:, :, jtr), &
                   & bmat=density(:, :, dtr, spin), &
-                  & cmat=response(:, :, itr, spin), beta=1.0_wp)
+                  & cmat=response(:, :, itr, spin), transb='T', beta=1.0_wp)
             end do
          end if
       end do
@@ -1104,8 +1110,7 @@ subroutine get_acp_projector_image_gradient(mol, bas, bcache, acp, acache, &
             do spin = 1, nspin
                call gemm(amat=images%scaled_projector_overlap(:, :, jtr), &
                   & bmat=density(:, :, dtr, spin), &
-                  & cmat=response_oracle(:, :, itr, spin), transb='T', &
-                  & beta=1.0_wp)
+                  & cmat=response_oracle(:, :, itr, spin), beta=1.0_wp)
             end do
             diff = images%projector_translation(:, jtr) &
                & - images%projector_translation(:, itr)
@@ -1114,7 +1119,8 @@ subroutine get_acp_projector_image_gradient(mol, bas, bcache, acp, acache, &
             do spin = 1, nspin
                call gemm(amat=images%scaled_projector_overlap(:, :, jtr), &
                   & bmat=density(:, :, dtr, spin), &
-                  & cmat=response_oracle(:, :, itr, spin), beta=1.0_wp)
+                  & cmat=response_oracle(:, :, itr, spin), transb='T', &
+                  & beta=1.0_wp)
             end do
          end do
       end do
