+++ b/tests/xTB/regtest-tblite-gxtb/H2_gxtb_1d_kp_symmetry_fused.inp
@@ -25,6 +25,7 @@
           ACCURACY 1.0
           METHOD GXTB
           &GXTB_ACCELERATION
+            ACP_MESH_CONTRACTION QUALIFY
             ACP_PROJECTOR_CACHE QUALIFY
             EXCHANGE_STREAM_BACKEND SYMMETRY_FUSED
             FORWARD_FOCK_QUALIFICATION QUALIFY
