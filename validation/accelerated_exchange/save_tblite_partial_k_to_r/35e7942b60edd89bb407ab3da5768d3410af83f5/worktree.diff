+                     & cache%bvk_kernel%reps(:, icell) &
+                     & -cache%bvk_kernel%reps(:, jcell), &
+                     & cache%bvk_phase_roots, &
+                     & cache%bvk_twist_phase(icell) &
+                     & *conjg(cache%bvk_twist_phase(jcell)), ik)
