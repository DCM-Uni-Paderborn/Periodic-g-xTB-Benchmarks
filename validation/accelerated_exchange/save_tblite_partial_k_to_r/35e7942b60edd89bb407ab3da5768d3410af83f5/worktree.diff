+   complex(wp), intent(in) :: matrix(:, :, :)
+
+   integer :: spin
+
+   hash = int(size(matrix, 3), int64)
+   do spin = 1, size(matrix, 3)
+      hash = exchange_hash_mix(hash, &
+         & exchange_hash_complex2(matrix(:, :, spin)))
+   end do
+end function exchange_hash_complex3
