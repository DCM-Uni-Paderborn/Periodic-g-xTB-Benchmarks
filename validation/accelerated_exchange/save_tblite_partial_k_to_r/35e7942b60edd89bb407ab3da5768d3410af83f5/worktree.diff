+            & ps_h0_diat_scale(1, jzp) == 0.0_wp) then
+            ksig(isp, jsp) = 0.0_wp
+         else
+            ksig(isp, jsp) = 2.0_wp/((1.0_wp/ps_h0_diat_scale(1, izp)) &
+               & + (1.0_wp/ps_h0_diat_scale(1, jzp)))
+         end if
+         if (ps_h0_diat_scale(2, izp) == 0.0_wp .or. &
+            & ps_h0_diat_scale(2, jzp) == 0.0_wp) then
+            kpi(isp, jsp) = 0.0_wp
+         else
+            kpi(isp, jsp) = 2.0_wp/((1.0_wp/ps_h0_diat_scale(2, izp)) &
+               & + (1.0_wp/ps_h0_diat_scale(2, jzp)))
+         end if
+         if (ps_h0_diat_scale(3, izp) == 0.0_wp .or. &
+            & ps_h0_diat_scale(3, jzp) == 0.0_wp) then
+            kdel(isp, jsp) = 0.0_wp
+         else
+            kdel(isp, jsp) = 2.0_wp/((1.0_wp/ps_h0_diat_scale(3, izp)) &
+               & + (1.0_wp/ps_h0_diat_scale(3, jzp)))
+         end if
       end do
    end do
 end subroutine get_diat_scale
