+            end if
+         end do
+      end do
+   end if
+   if (.not.reuse_kernel) then
+      call exchange%set_bvk_model_signature(cache)
+      call cache%set_bvk_signature(mol, nmesh, kfrac, weights)
+   end if
+end subroutine prepare_bvk_plan
