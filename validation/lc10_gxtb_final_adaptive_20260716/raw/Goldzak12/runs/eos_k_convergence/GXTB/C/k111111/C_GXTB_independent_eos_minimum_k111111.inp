&GLOBAL
  PRINT_LEVEL LOW
  PROJECT C_GXTB_independent_eos_minimum_k111111
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GXTB
          ACCURACY 0.05
        &END TBLITE
      &END XTB
    &END QS
    &KPOINTS
      SCHEME MACDONALD 11 11 11 0 0 0
      SYMMETRY T
      FULL_GRID F
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
    &END KPOINTS
    &SCF
      EPS_SCF 1.0E-9
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        METHOD DIRECT_P_MIXING
        ALPHA 0.2
      &END MIXING
      &PRINT
        &RESTART OFF
          BACKUP_COPIES 0
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      CANONICALIZE TRUE
      ABC 3.495045638400 3.495045638400 3.495045638400
      PERIODIC XYZ
      SYMMETRY CUBIC
    &END CELL
    &COORD
      SCALED
      C   0.000000000000  0.000000000000  0.000000000000
      C   0.000000000000  0.500000000000  0.500000000000
      C   0.500000000000  0.000000000000  0.500000000000
      C   0.500000000000  0.500000000000  0.000000000000
      C   0.250000000000  0.250000000000  0.250000000000
      C   0.250000000000  0.750000000000  0.750000000000
      C   0.750000000000  0.250000000000  0.750000000000
      C   0.750000000000  0.750000000000  0.250000000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
